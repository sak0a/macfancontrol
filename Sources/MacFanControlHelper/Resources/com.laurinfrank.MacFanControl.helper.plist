    <key>Program</key>
    <string>/Library/PrivilegedHelperTools/com.laurinfrank.MacFanControl.helper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Library/PrivilegedHelperTools/com.laurinfrank.MacFanControl.helper</string>
    </array>

    <key>MachServices</key>
    <dict>
        <key>com.laurinfrank.MacFanControl.helper</key>
