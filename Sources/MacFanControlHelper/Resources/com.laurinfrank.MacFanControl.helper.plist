    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardErrorPath</key>
    <string>/var/log/com.laurinfrank.MacFanControl.helper.log</string>

    <key>StandardOutPath</key>
    <string>/var/log/com.laurinfrank.MacFanControl.helper.log</string>
